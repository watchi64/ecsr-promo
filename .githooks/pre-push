#!/bin/sh
# Garde-fou release : GitHub Pages sert main directement, sans build ni CI.
# Si un push de main embarque des changements js/css SANS token ?v= rafraichi,
# la prod servirait du cache perime. Ce hook bloque ce cas precis.
#
# Complement de la garde "main seulement" du pre-commit : un merge dans main ne
# declenche PAS pre-commit (git utilise pre-merge-commit pour ca), donc apres un
# merge il faut lancer le cache-bust a la main — ce hook empeche de l'oublier.
#
# Forcer en connaissance de cause : git push --no-verify
#
# stdin : une ligne par ref poussee -> <local_ref> <local_sha> <remote_ref> <remote_sha>
while read local_ref local_sha remote_ref remote_sha; do
  [ "$remote_ref" = "refs/heads/main" ] || continue
  # Suppression de la branche distante : local_sha = 40 zeros, rien a verifier.
  case "$local_sha" in *[!0]*) ;; *) continue ;; esac
  # Branche distante inexistante (premier push) : pas de base de comparaison.
  case "$remote_sha" in *[!0]*) ;; *) continue ;; esac
  [ "$local_sha" = "$remote_sha" ] && continue

  # Des js/css changent-ils entre le remote et ce qu'on pousse ?
  if git diff --name-only "$remote_sha" "$local_sha" -- 'js' 'css' | grep -qE '\.(js|css)$'; then
    old_token=$(git show "$remote_sha:index.html" 2>/dev/null | grep -o '?v=[0-9a-z]*' | head -n 1)
    new_token=$(git show "$local_sha:index.html" 2>/dev/null | grep -o '?v=[0-9a-z]*' | head -n 1)
    if [ -n "$old_token" ] && [ "$old_token" = "$new_token" ]; then
      echo "[pre-push] REFUSE : push de main avec js/css modifies mais token ?v= inchange ($new_token)." >&2
      echo "[pre-push] La prod (GitHub Pages) servirait du cache perime." >&2
      echo "[pre-push] Lance :  node scripts/cache-bust.js  puis commit le re-versionnage, et re-pousse." >&2
      echo "[pre-push] (git push --no-verify pour forcer en connaissance de cause)" >&2
      exit 1
    fi
  fi
done
exit 0
